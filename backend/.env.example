# ============================================================
# Career Genius Backend - Environment Variables
# Copy to .env for local development
# Set these directly in Railway dashboard for production
# ============================================================

# Application
APP_NAME="Career Genius"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production

# Database
# Railway auto-injects DATABASE_URL when you add a PostgreSQL plugin
# For local dev, use SQLite:
DATABASE_URL=sqlite:///./career_genius.db
# DATABASE_URL=postgresql://user:password@localhost:5432/career_genius

# JWT Authentication — generate a strong key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# CORS Origins — comma-separated list of allowed frontend URLs
# Example for production: https://your-app.vercel.app
# Example for local:      http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
