# ============================================================
# Career Genius Backend - Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# Application
APP_NAME="Career Genius"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Database - Use PostgreSQL in production, SQLite for dev
DATABASE_URL=sqlite:///./career_genius.db
# DATABASE_URL=postgresql://user:password@localhost:5432/career_genius

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Email (optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS (for production file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
